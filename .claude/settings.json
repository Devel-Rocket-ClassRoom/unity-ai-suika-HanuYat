{
  "permissions": {
    "allow": [
      "Read",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(dotnet csharpier *)"
    ],
    "deny": [
      "Read(./Library/**)",
      "Read(!./Library/PackageCache/**)",
      "Read(./Temp/**)",
      "Read(./Logs/**)",
      "Read(./obj/**)",
      "Read(./**/*.csproj)",
      "Read(./**/*.sln)",
      "Write(./**/*.meta)",
      "Edit(./**/packages-lock.json)",
      "Edit(./**/*.unity)",
      "Write(./**/*.unity)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$json = [Console]::In.ReadToEnd() | ConvertFrom-Json; $f = $json.tool_input.file_path; if ($f -and $f.EndsWith('.cs')) { dotnet csharpier format \"$f\" 2>$null }; exit 0",
            "shell": "powershell",
            "statusMessage": "CSharpier 포매팅 중..."
          }
        ]
      }
    ]
  }
}